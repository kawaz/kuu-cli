# impl/mbt — MoonBit PoC 実装の task runner (kuu-cli DR-0001 §3)。
# ルートの justfile から `just impl-mbt-*` として呼び出される。

set shell := ["bash", "-euo", "pipefail", "-c"]

set script-interpreter := ["bash", "-euo", "pipefail"]

set positional-arguments

MBT_ROOT := justfile_directory()
# MBT_ROOT = .../kawaz/kuu-cli/main/impl/mbt
#   ../..     = .../kawaz/kuu-cli/main
#   ../../..  = .../kawaz/kuu-cli
#   ../../../.. = .../kawaz  (sibling repos live here)
KUU_MBT_ROOT := justfile_directory() + "/../../../../kuu.mbt/main"
# spec fixtures は KUU_FIXTURES 環境変数で注入可能 (kuu.mbt の conformance runner と同じ流儀)。
# 未設定なら sibling checkout の fixtures/ (dev 環境デフォルト)。CI は SHA-pin checkout の
# パスを KUU_FIXTURES で渡す。
FIXTURES := env("KUU_FIXTURES", justfile_directory() + "/../../../../kuu/main/fixtures")

default: lint test

# ---------- setup ----------

# kuu.mbt の main workspace を deps/kuu.mbt に用意する (moon.work member 解決用)。
# 判定順序 (codex #1 M-3 修正、統括裁定 2026-07-16):
#   1. deps/kuu.mbt が **real directory** (symlink でない実ディレクトリ) → そのまま受理。
#      CI の SHA-pin `git clone` checkout をこの path に置く想定 (DR-0001 §2 Consequences) で、
#      既存 checkout を上書き / 別 path に読み替えると再現性を壊す。**sibling 検査より先に置く**。
#   2. deps/kuu.mbt が symlink → 想定 path (../../../../../kuu.mbt/main) と一致するか確認、
#      違えば refresh (dev 環境の symlink 貼り替え)。sibling が無ければ error にせずリンク保持
#      (実体解決の diagnostic は moon 側に任せる)
#   3. deps/kuu.mbt が未作成 → sibling kuu.mbt の存在を検査し、リンクを作る (dev 環境の初回)。
#      **sibling 検査はここだけに移動**した (M-3 修正前は先頭で必須にしていたので CI checkout
#      を silently 拒否していた)
[script]
setup:
    link="{{MBT_ROOT}}/deps/kuu.mbt"
    ln_target="{{KUU_MBT_ROOT}}"
    if [[ -d "$link" && ! -L "$link" ]]; then
      # real directory (CI SHA-pin checkout 想定) — そのまま受理
      exit 0
    fi
    if [[ -L "$link" ]]; then
      cur=$(readlink "$link")
      if [[ "$cur" != "../../../../../kuu.mbt/main" ]]; then
        printf "impl/mbt: refreshing symlink deps/kuu.mbt -> ../../../../../kuu.mbt/main (was: %s)\n" "$cur"
        ln -sfn ../../../../../kuu.mbt/main "$link"
      fi
      exit 0
    fi
    if [[ -e "$link" ]]; then
      printf >&2 "impl/mbt: deps/kuu.mbt exists but is not a directory or symlink; leaving it alone\n"
      exit 0
    fi
    # deps/kuu.mbt 未作成 = dev 環境の初回。sibling が要る。
    if [[ ! -d "$ln_target" ]]; then
      printf >&2 "impl/mbt: kuu.mbt not found at %s\n" "$ln_target"
      printf >&2 "impl/mbt: check out kawaz/kuu.mbt as a sibling of kawaz/kuu-cli, or place a SHA-pin checkout at deps/kuu.mbt.\n"
      exit 2
    fi
    printf "impl/mbt: creating symlink deps/kuu.mbt -> ../../../../../kuu.mbt/main\n"
    ln -sfn ../../../../../kuu.mbt/main "$link"

# ---------- lint / test ----------

# moon fmt --check は現在の moon toolchain (0.1.20260709) と formatter の間で
# `options("is-main":true)` vs `pkgtype(kind:"executable")` の書式が食い違うため一時 skip。
# 別 issue で追跡 (impl/mbt/README.md の Known issues 参照)。
lint: setup
    cd "{{MBT_ROOT}}" && moon check --target native

# cli パッケージのみ実行 (deps/kuu.mbt の 346 test は kuu.mbt 側の関心、ここでは走らせない)。
test: setup
    cd "{{MBT_ROOT}}" && moon test cli/src/lib --target native
    cd "{{MBT_ROOT}}" && just e2e

# CLI レベル e2e: kuu/fixtures の代表 case を fixture 本体から case id 経由で消費し、compiled
# binary の出力が fixture expect の代表 field と一致することを pin する。
#
# **fixture 審判化** (codex #1 M-2 修正、統括裁定 2026-07-16): 旧実装は fixture の `.definition`
# だけ読んで args と期待値を justfile 側に hardcode していた — fixture case が改名 / 削除 / 意味
# 変更されても hardcode が古い期待値と一致すれば silent pass する構造で、実際 codex レビュー時に
# C-1 (front_door 後段処理欠落) を見逃す原因になった。新実装は `.cases[] | select(.id==$id)` で
# **args も expected も fixture 本体から jq で読む** ため、fixture 側の変更は必ず e2e に反映される。
#
# 現在の pin 対象 (5 case、代表軸を網羅):
#   - multiple-parse/separator-typed :: option-separator-number-success   (separator + type parse)
#   - export-key/rename              :: rename-projection                 (export_key: result rename)
#   - export-key/collision           :: co-exposure-collision             (Ambiguous 昇格 = C-1 の再発検知軸)
#   - inheritable-parse/basic        :: ancestor-inherit-flowdown         (resolve 相の inherit 流下 = C-1 の再発検知軸)
#   - alias-parse/deprecated         :: deprecated-entry-warns            (構造化 warnings + sentinel 除外 = M-1 の再発検知軸)
#
# **spec fixture の緩比較全体 (CONFORMANCE.md §3) を再現するのはスコープ外** (v1 決定リスト 8、
# 全 fixture 走査の conformance gate 化は別サイクル、統括裁定)。ここでは fixture 側の args / 期待
# 代表 field を「そのまま」読んで pin する層に留める。
[script]
e2e:
    # binary path 固定 (codex #1 m-1 修正、統括裁定 2026-07-16): `moon build --target native`
    # は default = debug build なので、出力は `_build/native/debug/build/...`。旧実装は release
    # path を先に探して fallback `find|head -1` で拾っていたが、workspace に stale build や
    # 別 executable が混ざると誤実行しうる。build mode と exact artifact path を対で固定し、
    # find fallback を削除する。
    cd "{{MBT_ROOT}}" && moon build --target native
    bin="{{MBT_ROOT}}/_build/native/debug/build/kawaz/kuu-cli-mbt/main/main.exe"
    if [[ ! -x "$bin" ]]; then
      printf >&2 "e2e: main binary not found at expected path %s (moon build failed or output layout changed?)\n" "$bin"
      exit 2
    fi
    def_only=$(mktemp)
    trap 'rm -f "$def_only"' EXIT

    # fixture の case を id で引いて (args, expect) を返すための shell function。
    #   read_case_args   <fixture_path> <case_id>  → args 配列 (改行区切り、bash mapfile 用)
    #   read_case_expect <fixture_path> <case_id> <jq_path> → expect のうち jq_path で射影した文字列
    # fixture / case が見つからない・args 配列でない場合は診断して exit 1。
    read_case_args() {
      local fx="$1" id="$2"
      if [[ ! -f "$fx" ]]; then
        printf >&2 "e2e: fixture not found at %s (kawaz/kuu checkout missing?)\n" "$fx"
        exit 2
      fi
      local args_json
      args_json=$(jq -r --arg id "$id" '(.cases[] | select(.id==$id) | .args) // empty' "$fx")
      if [[ -z "$args_json" ]]; then
        printf >&2 "e2e: case id '%s' not found in %s\n" "$id" "$fx"
        exit 1
      fi
      # `.args | .[]` で行分割: bash mapfile が食える形にする (string 内の改行は fixture が排除)
      jq -r --arg id "$id" '.cases[] | select(.id==$id) | .args[]' "$fx"
    }
    read_case_expect() {
      local fx="$1" id="$2" path="$3"
      jq -c --arg id "$id" ".cases[] | select(.id==\$id) | .expect | $path" "$fx"
    }
    # (fixture, case_id, args, expect の代表 field) を対で pin する共通関数。
    #   assert_eq  <label> <got> <want>
    assert_eq() {
      local label="$1" got="$2" want="$3"
      if [[ "$got" != "$want" ]]; then
        printf >&2 "e2e FAIL (%s): got=%s want=%s\n" "$label" "$got" "$want"
        exit 1
      fi
    }

    # ── case 1: multiple-parse/separator-typed :: option-separator-number-success ──
    # (conformance sweep が全 parse fixture を走査するのに対し、ここは push gate に入る green 必須の
    # 代表 pin。sweep は情報収集モードで gate ではない — 役割が違うので両方持つ)
    # separator + type parse: fixture の args ["--ports","5,7"] を読み、期待の result.ports が実バイナリの
    # 出力と一致することを pin。
    fixture="{{FIXTURES}}/multiple-parse/separator-typed.json"
    id="option-separator-number-success"
    jq '.definition' "$fixture" > "$def_only"
    mapfile -t args < <(read_case_args "$fixture" "$id")
    out=$("$bin" parse "$def_only" -- "${args[@]}")
    assert_eq "$id outcome"     "$(jq -r '.outcome'    <<<"$out")" "success"
    assert_eq "$id result.ports" "$(jq -c '.result.ports' <<<"$out")" "$(read_case_expect "$fixture" "$id" '.result.ports')"
    printf "e2e OK: separator-typed.json %s -> success, ports=%s\n" "$id" "$(jq -c '.result.ports' <<<"$out")"

    # ── case 2: export-key/rename :: rename-projection ──
    # export_key: "alias" が result キーを rename し、effects の entity は cell name のまま
    # (front_door export_map(ast) 経路の実機確認)。
    fixture="{{FIXTURES}}/export-key/rename.json"
    id="rename-projection"
    jq '.definition' "$fixture" > "$def_only"
    mapfile -t args < <(read_case_args "$fixture" "$id")
    out=$("$bin" parse "$def_only" -- "${args[@]}")
    assert_eq "$id outcome" "$(jq -r '.outcome' <<<"$out")" "success"
    assert_eq "$id result"  "$(jq -c '.result'  <<<"$out")" "$(read_case_expect "$fixture" "$id" '.result')"
    # effects の第 1 要素の entity は fixture expected の 1 番目と一致 (kv 順序は spec 上安定)
    assert_eq "$id effects[0].entity" \
              "$(jq -r '.effects[0].entity' <<<"$out")" \
              "$(jq -r --arg id "$id" '.cases[] | select(.id==$id) | .expect.effects[0].entity' "$fixture")"
    printf "e2e OK: rename.json %s -> success, result=%s, entity=port\n" "$id" "$(jq -c '.result' <<<"$out")"

    # ── case 3: export-key/collision :: co-exposure-collision (Ambiguous 昇格) ──
    # front_door.parse が spec DR-021 → DR-073 の export-key 共露出昇格を含むかを CLI 経由で pin。
    # C-1 の再発検知軸: 玄関 API が薄い parse_tree wrapper に退化すると Success を返して e2e が silently
    # 通ってしまう構造 (codex #1 の C-1 発見の原因) が再発しないことを確認する。fixture 期待の
    # interpretations 個数と CLI 出力の interpretations 配列長を比較 (JSON 形の詳細は wire.mbt の
    # 「PoC 仮置き #1」で未確定なので長さで pin)。
    fixture="{{FIXTURES}}/export-key/collision.json"
    id="co-exposure-collision"
    jq '.definition' "$fixture" > "$def_only"
    mapfile -t args < <(read_case_args "$fixture" "$id")
    # ambiguous は wire exit code 1 だが e2e は成功扱いにするため subshell + $? を素直に取る
    set +e
    out=$("$bin" parse "$def_only" -- "${args[@]}")
    ec=$?
    set -e
    assert_eq "$id outcome" "$(jq -r '.outcome' <<<"$out")" "ambiguous"
    assert_eq "$id exit"    "$ec" "1"
    got_len=$(jq -r '.interpretations | length' <<<"$out")
    want_len=$(jq -r --arg id "$id" '.cases[] | select(.id==$id) | .expect.interpretations | length' "$fixture")
    assert_eq "$id interpretations.length" "$got_len" "$want_len"
    printf "e2e OK: collision.json %s -> ambiguous, interpretations.length=%s\n" "$id" "$got_len"

    # ── case 4: inheritable-parse/basic :: ancestor-inherit-flowdown (resolve 相の inherit 流下) ──
    # front_door.resolve が値源ラダーの inherit 席を子 scope まで流下させるかを CLI 経由で pin。
    # C-1 の再発検知軸: 玄関 `parse` だけ呼んで `resolve` を呼び忘れると result.sub が空になる
    # (旧 wire.mbt が実際にこのバグを持っていた)。fixture 期待の result.sub.ttl (=30) が実バイナリの
    # 出力と一致することで、resolve 相の起動と inherit の流下を同時に確認する。
    fixture="{{FIXTURES}}/inheritable-parse/basic.json"
    id="ancestor-inherit-flowdown"
    jq '.definition' "$fixture" > "$def_only"
    mapfile -t args < <(read_case_args "$fixture" "$id")
    out=$("$bin" parse "$def_only" -- "${args[@]}")
    assert_eq "$id outcome"        "$(jq -r '.outcome'         <<<"$out")" "success"
    assert_eq "$id result.sub.ttl" "$(jq -c '.result.sub.ttl'  <<<"$out")" "$(read_case_expect "$fixture" "$id" '.result.sub.ttl')"
    assert_eq "$id result.ttl"     "$(jq -c '.result.ttl'      <<<"$out")" "$(read_case_expect "$fixture" "$id" '.result.ttl')"
    printf "e2e OK: inheritable basic.json %s -> success, result=%s\n" "$id" "$(jq -c '.result' <<<"$out")"

    # ── case 5: alias-parse/deprecated :: deprecated-entry-warns (構造化 warnings + sentinel 除外) ──
    # spec CONFORMANCE §2 の warnings 面 (`[{element, kind}]`) と、@depr sentinel が effects に
    # 漏れないこと (kuu.mbt `is_sentinel` pub 化 + kuu-cli 側の切替え) を CLI 経由で pin。M-1 の再発
    # 検知軸: sentinel 判定が狭いままだと @depr:port が effects[] に紛れ込んで検出可能。
    fixture="{{FIXTURES}}/alias-parse/deprecated.json"
    id="deprecated-entry-warns"
    jq '.definition' "$fixture" > "$def_only"
    mapfile -t args < <(read_case_args "$fixture" "$id")
    out=$("$bin" parse "$def_only" -- "${args[@]}")
    assert_eq "$id outcome"  "$(jq -r '.outcome' <<<"$out")" "success"
    assert_eq "$id warnings" "$(jq -c '.warnings' <<<"$out")" "$(read_case_expect "$fixture" "$id" '.warnings')"
    # @depr: sentinel が effects に混じらない (M-1 の再発検知)。
    depr_leak=$(jq -r '[.effects[]?.entity | select(startswith("@depr:"))] | length' <<<"$out")
    assert_eq "$id @depr sentinel leak" "$depr_leak" "0"
    printf "e2e OK: deprecated.json %s -> success, warnings=%s, no @depr in effects\n" "$id" "$(jq -c '.warnings' <<<"$out")"

# ---------- conformance sweep (情報収集モード) ----------

# 全 parse fixture を CLI 経由で走らせ、expect との field 単位一致を集計する骨格。
#
# **green gate ではない** (v1 決定リスト 8 = conformance gate 化は envelope 裁定 (UX-Q) 後の
# 別タスク、統括指示 2026-07-16)。未実装機能で落ちる case を含めて pass/fail/skip を集計し、
# 「現在何割通るか」を可視化する情報収集モード。exit code は常に 0 (集計の印字が成果物)。
#
# 比較は e2e 5 case と同じ field 単位の厳密一致 (outcome + expect の各 top-level key)。
# CONFORMANCE.md §3 の緩比較の完全実装はスコープ外 (同上の別タスク)。
#
# skip 対象: query が parse 以外の fixture (complete / definition_error は envelope 未確定領域)。
[script]
conformance:
    cd "{{MBT_ROOT}}" && moon build --target native
    bin="{{MBT_ROOT}}/_build/native/debug/build/kawaz/kuu-cli-mbt/main/main.exe"
    if [[ ! -x "$bin" ]]; then
      printf >&2 "conformance: main binary not found at %s\n" "$bin"
      exit 2
    fi
    fixtures_root="{{FIXTURES}}"
    if [[ ! -d "$fixtures_root" ]]; then
      printf >&2 "conformance: fixtures dir not found at %s (set KUU_FIXTURES or check out kawaz/kuu as sibling)\n" "$fixtures_root"
      exit 2
    fi
    def_only=$(mktemp); fail_log=$(mktemp)
    trap 'rm -f "$def_only" "$fail_log"' EXIT
    pass=0; fail=0; skip=0
    for fx in "$fixtures_root"/*/*.json; do
      rel="${fx#"$fixtures_root"/}"
      query=$(jq -r '.query // "parse"' "$fx")
      n_cases=$(jq -r '.cases | length' "$fx")
      if [[ "$query" != "parse" ]]; then
        skip=$((skip + n_cases))
        continue
      fi
      jq '.definition' "$fx" > "$def_only"
      for i in $(seq 0 $((n_cases - 1))); do
        id=$(jq -r --argjson i "$i" '.cases[$i].id' "$fx")
        mapfile -t args < <(jq -r --argjson i "$i" '.cases[$i].args[]' "$fx")
        # 出力比較なので exit code は見ない (failure/ambiguous も JSON は stdout に出る)
        set +e
        out=$("$bin" parse "$def_only" -- "${args[@]}" 2>/dev/null)
        set -e
        if ! jq -e . <<<"$out" >/dev/null 2>&1; then
          fail=$((fail + 1))
          printf "FAIL %s :: %s (no JSON output)\n" "$rel" "$id" >> "$fail_log"
          continue
        fi
        case_ok=1
        for key in $(jq -r --argjson i "$i" '.cases[$i].expect | keys[]' "$fx"); do
          want=$(jq -c --argjson i "$i" ".cases[\$i].expect.\"$key\"" "$fx")
          got=$(jq -c ".\"$key\"" <<<"$out")
          if [[ "$got" != "$want" ]]; then
            case_ok=0
            printf "FAIL %s :: %s (.%s: got=%s want=%s)\n" "$rel" "$id" "$key" "$got" "$want" >> "$fail_log"
            break
          fi
        done
        if [[ "$case_ok" == 1 ]]; then pass=$((pass + 1)); else fail=$((fail + 1)); fi
      done
    done
    total=$((pass + fail))
    echo "──── conformance sweep (parse fixtures, informational) ────"
    if [[ -s "$fail_log" ]]; then cat "$fail_log"; fi
    printf "conformance: %d/%d parse cases pass (%d fail), %d skipped (query != parse)\n" \
      "$pass" "$total" "$fail" "$skip"
